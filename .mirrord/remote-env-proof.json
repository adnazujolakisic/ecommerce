{
  "target": {
    "path": {
      "deployment": "checkout"
    },
    "namespace": "metalmart"
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord=remote-env\\b"
        }
      },
      "outgoing": {
        "tcp": true,
        "udp": true
      },
      "dns": true
    },
    "fs": "read",
    "env": true
  },
  "operator": true
}
